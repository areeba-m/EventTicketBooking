{
  "info": {
    "name": "EventTicketBooking API",
    "_postman_id": "e6f6a2c0-0000-4000-8000-000000000000",
    "description": "Collection for testing EventTicketBooking FastAPI endpoints",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth - Register Attendee",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Alice Attendee\",\n  \"email\": \"alice@example.com\",\n  \"password\": \"SecurePass123\",\n  \"role\": \"attendee\"\n}"
        },
        "url": { "raw": "{{base_url}}/auth/register", "host": ["{{base_url}}"], "path": ["auth","register"] }
      }
    },
    {
      "name": "Auth - Register Organizer",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Olivia Organizer\",\n  \"email\": \"olivia@example.com\",\n  \"password\": \"SecurePass123\",\n  \"role\": \"organizer\"\n}"
        },
        "url": { "raw": "{{base_url}}/auth/register", "host": ["{{base_url}}"], "path": ["auth","register"] }
      }
    },
    {
      "name": "Auth - Login",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"alice@example.com\",\n  \"password\": \"SecurePass123\"\n}"
        },
        "url": { "raw": "{{base_url}}/auth/login", "host": ["{{base_url}}"], "path": ["auth","login"] }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "var json = pm.response.json();",
              "if (json && json.access_token) { pm.environment.set('access_token', json.access_token); }"
            ]
          }
        }
      ]
    },
    {
      "name": "Create Event (Organizer)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{access_token}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Summer Concert\",\n  \"date\": \"2026-06-15T19:00:00Z\",\n  \"venue\": \"Town Hall\",\n  \"total_seats\": 250\n}"
        },
        "url": { "raw": "{{base_url}}/events", "host": ["{{base_url}}"], "path": ["events"] }
      },
      "event": [
        {
          "listen": "test",
          "script": { "exec": ["var json = pm.response.json(); if (json && json.id) pm.environment.set('event_id', json.id);"] }
        }
      ]
    },
    {
      "name": "List Events",
      "request": {
        "method": "GET",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": {
          "raw": "{{base_url}}/events?start_date={{start_date}}&end_date={{end_date}}&venue={{venue}}&skip={{skip}}&limit={{limit}}",
          "host": ["{{base_url}}"],
          "path": ["events"]
        }
      }
    },
    {
      "name": "Get Event",
      "request": {
        "method": "GET",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": { "raw": "{{base_url}}/events/{{event_id}}", "host": ["{{base_url}}"], "path": ["events","{{event_id}}"] }
      }
    },
    {
      "name": "Update Event (Organizer)",
      "request": {
        "method": "PUT",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{access_token}}" }
        ],
        "body": { "mode": "raw", "raw": "{\n  \"title\": \"Summer Concert - Evening\",\n  \"total_seats\": 300\n}" },
        "url": { "raw": "{{base_url}}/events/{{event_id}}", "host": ["{{base_url}}"], "path": ["events","{{event_id}}"] }
      }
    },
    {
      "name": "Delete Event (Organizer)",
      "request": {
        "method": "DELETE",
        "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
        "url": { "raw": "{{base_url}}/events/{{event_id}}", "host": ["{{base_url}}"], "path": ["events","{{event_id}}"] }
      }
    },
    {
      "name": "Create Booking (Attendee)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{access_token}}" }
        ],
        "body": { "mode": "raw", "raw": "{\n  \"event_id\": \"{{event_id}}\",\n  \"seats\": 2\n}" },
        "url": { "raw": "{{base_url}}/bookings", "host": ["{{base_url}}"], "path": ["bookings"] }
      },
      "event": [
        {
          "listen": "test",
          "script": { "exec": ["var json = pm.response.json(); if (json && json.id) pm.environment.set('booking_id', json.id);"] }
        }
      ]
    },
    {
      "name": "List My Bookings (Attendee)",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
        "url": { "raw": "{{base_url}}/bookings/me", "host": ["{{base_url}}"], "path": ["bookings","me"] }
      }
    },
    {
      "name": "Cancel Booking (Attendee)",
      "request": {
        "method": "DELETE",
        "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
        "url": { "raw": "{{base_url}}/bookings/{{booking_id}}", "host": ["{{base_url}}"], "path": ["bookings","{{booking_id}}"] }
      }
    },
    {
      "name": "Analytics - Events (Organizer)",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
        "url": { "raw": "{{base_url}}/analytics/events?start_date={{start_date}}&end_date={{end_date}}&venue={{venue}}&skip={{skip}}&limit={{limit}}", "host": ["{{base_url}}"], "path": ["analytics","events"] }
      }
    },
    {
      "name": "Analytics - Users (Organizer)",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
        "url": { "raw": "{{base_url}}/analytics/users?skip={{skip}}&limit={{limit}}", "host": ["{{base_url}}"], "path": ["analytics","users"] }
      }
    },
    {
      "name": "Analytics - Revenue (Organizer)",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
        "url": { "raw": "{{base_url}}/analytics/revenue?start_date={{start_date}}&end_date={{end_date}}", "host": ["{{base_url}}"], "path": ["analytics","revenue"] }
      }
    }
  ],
  "variable": [
    { "key": "base_url", "value": "http://localhost:8000" },
    { "key": "access_token", "value": "" },
    { "key": "event_id", "value": "" },
    { "key": "booking_id", "value": "" },
    { "key": "start_date", "value": "2026-06-01T00:00:00Z" },
    { "key": "end_date", "value": "2026-06-30T23:59:59Z" },
    { "key": "venue", "value": "Town Hall" },
    { "key": "skip", "value": "0" },
    { "key": "limit", "value": "20" }
  ]
}
